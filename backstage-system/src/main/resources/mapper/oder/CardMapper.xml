<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backstage.system.mapper.order.CardMapper">
    
    <resultMap type="Card" id="CardResult">
        <result property="id"    column="id"    />
        <result property="title"    column="title"    />
        <result property="type"    column="type"    />
        <result property="price"    column="price"    />
        <result property="goodsId"    column="goods_id"    />
        <result property="startTime"    column="start_time"    />
        <result property="endTime"    column="end_time"    />
        <result property="used"    column="used"    />
    </resultMap>

    <sql id="selectCardVo">
        select id, title, type, price, goods_id, start_time, end_time, used from osh_card
    </sql>

    <select id="selectCardList" parameterType="Card" resultMap="CardResult">
        <include refid="selectCardVo"/>
        <where>  
            <if test="id != null"> and id = #{id}</if>
            <if test="title != null  and title != ''"> and title like concat('%', #{title}, '%')</if>
            <if test="type != null  and type != ''"> and type = #{type}</if>
            <if test="price != null "> and price = #{price}</if>
            <if test="goodsId != null "> and goods_id = #{goodsId}</if>
            <if test="used != null "> and used = #{used}</if>
        </where>
    </select>
    
    <select id="selectCardById" parameterType="Long" resultMap="CardResult">
        <include refid="selectCardVo"/>
        where id = #{id}
    </select>

    <insert id="insertCard" parameterType="Card" useGeneratedKeys="true" keyProperty="id">
        insert into osh_card
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null">title,</if>
            <if test="type != null">type,</if>
            <if test="price != null">price,</if>
            <if test="goodsId != null">goods_id,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="used != null">used,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null">#{title},</if>
            <if test="type != null">#{type},</if>
            <if test="price != null">#{price},</if>
            <if test="goodsId != null">#{goodsId},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="used != null">#{used},</if>
         </trim>
    </insert>

    <update id="updateCard" parameterType="Card">
        update osh_card
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null">title = #{title},</if>
            <if test="type != null">type = #{type},</if>
            <if test="price != null">price = #{price},</if>
            <if test="goodsId != null">goods_id = #{goodsId},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="used != null">used = #{used},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteCardById" parameterType="Long">
        delete from osh_card where id = #{id}
    </delete>

    <delete id="deleteCardByIds" parameterType="String">
        delete from osh_card where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
