<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backstage.system.mapper.user.OshPermissionMapper">

    <select id="selectPermissionIdsByRoleId" resultType="java.lang.Integer">
        select permission_id from osh_role_permission where role_id = #{roleId}
    </select>
    <select id="selectPermissionCodeByIds" resultType="java.lang.String">
        select permission_code from osh_permission where id in
        <foreach item="item" index="index" collection="permissionIds" open="(" separator="," close=")">
            #{item}
        </foreach>
    </select>
</mapper>