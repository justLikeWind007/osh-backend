<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backstage.system.mapper.user.OshPermissionMapper">

    <select id="selectPermissionIdsByRoleIds" resultType="java.lang.Integer">
        SELECT permission_id FROM osh_role_permission
        WHERE role_id IN
        <foreach item="item" collection="roleIds" separator="," open="(" close=")">
            #{item}
        </foreach>
        AND delete_flag = 0
    </select>

</mapper>