<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backstage.system.mapper.user.OshUserMapper">

    <resultMap type="OshUser" id="UserResult">
        <result property="id"     column="id"      />
        <result property="username"     column="username"      />
        <result property="nickname"     column="nickname"      />
        <result property="email"     column="email"      />
        <result property="password"     column="password"      />
        <result property="avatar"     column="avatar"      />
        <result property="sex"     column="sex"      />
        <result property="introduction"     column="introduction"      />
        <result property="status"     column="status"      />
        <result property="createTime"     column="create_time"      />
        <result property="createBy"     column="create_by"      />
        <result property="updateTime"     column="update_time"      />
        <result property="updateBy"     column="update_by"      />
        <result property="deleteFlag"     column="delete_flag"      />
    </resultMap>

    <sql id="selectUser">
        select id, username, nickname, email, password, avatar, sex, `introduction`, `status`, create_time, create_by, update_time, update_by, delete_flag from osh_user
    </sql>

    <select id="getUserByUsername" resultMap="UserResult">
        <include refid="selectUser"/>
        where username = #{username}
    </select>

    <select id="getUserByUsernameOrEmail" resultType="com.backstage.system.domain.user.OshUser">
        <include refid="selectUser"/>
        where username = #{name} or email = #{name}
    </select>

    <select id="getUserByEmail" resultType="com.backstage.system.domain.user.OshUser">
        <include refid="selectUser"/>
        where email = #{email}
    </select>

    <insert id="register">
        insert into osh_user (id, username, email, password, create_time, create_by, update_time, update_by) values (#{userId}, #{username}, #{email}, #{password}, now(), #{userId}, now(), #{userId});
    </insert>

    <insert id="addUniqueId">
        insert into osh_user_unique(user_id, unique_id, create_time, create_by, update_time, update_by) values (#{userId}, #{uniqueId}, now(), #{userId}, now(), #{userId})
    </insert>

    <insert id="addRole">
        insert into osh_user_role values (#{userId}, 1, now(), #{userId}, now(), #{userId}, 0)
    </insert>

    <select id="getUniqueIdByUserId" resultType="java.lang.String">
        select unique_id from osh_user_unique where user_id = #{userId}
    </select>

    <select id="getUserIdByUniqueId" resultType="java.lang.Long">
        select user_id from osh_user_unique where unique_id = #{uniqueId}
    </select>

    <update id="updateUniqueIdByUserId">
        update osh_user_unique set unique_id = #{uniqueId} where user_id = #{userId}
    </update>

    <update id="updatePasswordByEmail" >
        update osh_user set password = #{password} where email = #{email}
    </update>

    <update id="updatePasswordById" >
        update osh_user set password = #{password} where id = #{userId}
    </update>

    <update id="updateUserInfoById" >
        update osh_user set avatar = #{avatar}, nickname = #{nickname}, sex = #{sex} where id = #{userId}
    </update>

    <select id="getPasswordById" resultType="java.lang.String">
        select password from osh_user where id = #{userId}
    </select>
    <select id="getUserInfoById" resultMap="UserResult">
        <include refid="selectUser"/>
        where status = 0 and id = #{userId}
    </select>

    <update id="updateEmailById">
        update osh_user set email = #{email} where id = #{userId}
    </update>

    <update id="deleteUniqueId">
        update osh_user_unique set delete_flag = 1 where user_id = #{userId}
    </update>





