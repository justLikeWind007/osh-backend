<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backstage.system.mapper.bbs.OshBbsCategoryMapper">

    <resultMap id="OshBbsCategoryResult" type="com.backstage.system.domain.bbs.OshBbsCategory">
        <id property="id" column="id" />
        <result property="title" column="title" />
        <result property="image" column="image" />
        <result property="sort" column="sort" />
        <result property="isDelete" column="is_delete" />
    </resultMap>

    <select id="selectCategoryList" parameterType="com.backstage.system.domain.bbs.OshBbsCategory" resultMap="OshBbsCategoryResult">
        SELECT id, title, image, sort
        FROM osh_bbs_category
        WHERE is_delete = 0
        ORDER BY sort ASC
    </select>

    <select id="countTotalUsers" resultType="Long">
        SELECT count(*) FROM sys_user WHERE del_flag = '0'
    </select>

    <select id="countTotalPosts" resultType="Long">
        SELECT count(*) FROM osh_bbs_post WHERE is_delete = 0
    </select>

</mapper>