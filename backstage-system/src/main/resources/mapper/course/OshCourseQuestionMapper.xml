<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backstage.system.mapper.course.OshCourseQuestionMapper">

    <resultMap id="OshCourseQuestionResult" type="com.backstage.system.domain.course.OshCourseQuestion">
        <id property="id" column="id"/>
        <result property="courseId" column="course_id"/>
        <result property="sectionId" column="section_id"/>
        <result property="userId" column="user_id"/>
        <result property="questionId" column="question_id"/>
        <result property="parentId" column="parent_id"/>
        <result property="recordType" column="record_type"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="solveStatus" column="solve_status"/>
        <result property="acceptedAnswerId" column="accepted_answer_id"/>
        <result property="replyCount" column="reply_count"/>
        <result property="lastReplyTime" column="last_reply_time"/>
        <result property="status" column="status"/>
        <result property="deleteFlag" column="delete_flag"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <insert id="insertCourseQuestion" parameterType="com.backstage.system.domain.course.OshCourseQuestion"
            useGeneratedKeys="true" keyProperty="id">
        insert into osh_course_question (
            course_id,
            section_id,
            user_id,
            question_id,
            parent_id,
            record_type,
            title,
            content,
            solve_status,
            accepted_answer_id,
            reply_count,
            last_reply_time,
            status,
            delete_flag,
            create_by,
            create_time,
            update_by,
            update_time
        ) values (
            #{courseId},
            #{sectionId},
            #{userId},
            #{questionId},
            #{parentId},
            #{recordType},
            #{title},
            #{content},
            #{solveStatus},
            #{acceptedAnswerId},
            #{replyCount},
            #{lastReplyTime},
            #{status},
            #{deleteFlag},
            #{createBy},
            #{createTime},
            #{updateBy},
            #{updateTime}
        )
    </insert>

    <select id="selectQuestionById" resultMap="OshCourseQuestionResult">
        select id,
               course_id,
               section_id,
               user_id,
               question_id,
               parent_id,
               record_type,
               title,
               content,
               solve_status,
               accepted_answer_id,
               reply_count,
               last_reply_time,
               status,
               delete_flag,
               create_by,
               create_time,
               update_by,
               update_time
        from osh_course_question
        where id = #{id}
          and delete_flag = 0
    </select>

    <update id="updateQuestionReplyMeta">
        update osh_course_question
        set reply_count = reply_count + 1,
            last_reply_time = #{lastReplyTime},
            update_by = #{updateBy},
            update_time = #{lastReplyTime}
        where id = #{questionId}
          and delete_flag = 0
    </update>
</mapper>
