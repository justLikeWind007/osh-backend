            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <!-- 修改课程 -->
    <update id="updateCourse" parameterType="com.backstage.system.domain.course.OshCourse">
        update osh_course
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="cover != null and cover != ''">cover = #{cover},</if>
            <if test="intro != null and intro != ''">intro = #{intro},</if>
            <if test="serviceContent != null and serviceContent != ''">service_content = #{serviceContent},</if>
            <if test="price != null">price = #{price},</if>
            <if test="tPrice != null">t_price = #{tPrice},</if>
            <if test="type != null and type != ''">type = #{type},</if>
            <if test="subCount != null">sub_count = #{subCount},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
            <if test="totalDuration != null">total_duration = #{totalDuration},</if>
            <if test="videoCount != null">video_count = #{videoCount},</if>
            <if test="salesCount != null">sales_count = #{salesCount},</if>
            <if test="viewCount != null">view_count = #{viewCount},</if>
            <if test="freeLessonCount != null">free_lesson_count = #{freeLessonCount},</if>
            <if test="likeCount != null">like_count = #{likeCount},</if>
            <if test="commentCount != null">comment_count = #{commentCount},</if>
            <if test="ratingScore != null">rating_score = #{ratingScore},</if>
            <if test="freeType != null">free_type = #{freeType},</if>
            <if test="afterServiceDays != null">after_service_days = #{afterServiceDays},</if>
            <if test="resourceType != null">resource_type = #{resourceType},</if>
            <if test="level != null">level = #{level},</if>
            <if test="status != null">status = #{status},</if>
            <if test="examId != null">exam_id = #{examId},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
        </trim>
        where id = #{id}
    </update>

    <!-- 删除课程 -->
    <delete id="deleteCourseById" parameterType="Long">
        delete from osh_course where id = #{id}
    </delete>

    <!-- 批量删除课程 -->
    <delete id="deleteCourseByIds" parameterType="String">
        delete from osh_course where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="getCourseMaterials" resultMap="OshCourseMaterial">
        select id,
               course_id,
               name,
               url,
               file_size,
               file_type,
               download_count,
               pay_only as pay_only,
               sort,
               delete_flag,
               create_by,
               create_time,
               update_by,
               update_time
        from osh_course_material
        where course_id = #{courseId}
          and delete_flag = 0
        order by sort asc, id asc
    </select>

    <update id="updateCourseSubCount" parameterType="java.util.Map">
        update osh_course
        <set>
            <if test="subCount != null">sub_count = #{subCount},</if>
            <if test="videoCount != null">video_count = #{videoCount},</if>
            update_time = now()
        </set>
        where id = #{courseId}
    </update>

    <update id="deleteCourseSectionById">
        update osh_course_section
        set delete_flag = 1,
        update_by = #{updateBy},
        update_time = now()
        where id = #{id}
    </update>

    <update id="deleteCourseSectionsByParentId">
        update osh_course_section
        set delete_flag = 1,
        update_by = #{updateBy},
        update_time = now()
        where parent_id = #{parentId} or id = #{parentId}
    </update>
</mapper>
