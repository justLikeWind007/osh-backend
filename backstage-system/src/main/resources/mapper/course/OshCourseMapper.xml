        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="courseId != null">course_id,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="sort != null">sort,</if>
            <if test="freeFlag != null">free_flag,</if>
            <if test="duration != null">duration,</if>
            <if test="mediaUrl != null and mediaUrl != ''">media_url,</if>
            <if test="cover != null and cover != ''">cover,</if>
            <if test="textContent != null and textContent != ''">text_content,</if>
            <if test="videoDesc != null and videoDesc != ''">video_desc,</if>
            <if test="videoCodec != null and videoCodec != ''">video_codec,</if>
            <if test="videoBitrate != null">video_bitrate,</if>
            <if test="videoResolution != null and videoResolution != ''">video_resolution,</if>
            <if test="fileSize != null">file_size,</if>
            <if test="type != null and type != ''">type,</if>
            <if test="status != null">status,</if>
            <if test="examId != null">exam_id,</if>
            <if test="deleteFlag != null">delete_flag,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="courseId != null">#{courseId},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="sort != null">#{sort},</if>
            <if test="freeFlag != null">#{freeFlag},</if>
            <if test="duration != null">#{duration},</if>
            <if test="mediaUrl != null and mediaUrl != ''">#{mediaUrl},</if>
            <if test="cover != null and cover != ''">#{cover},</if>
            <if test="textContent != null and textContent != ''">#{textContent},</if>
            <if test="videoDesc != null and videoDesc != ''">#{videoDesc},</if>
            <if test="videoCodec != null and videoCodec != ''">#{videoCodec},</if>
            <if test="videoBitrate != null">#{videoBitrate},</if>
            <if test="videoResolution != null and videoResolution != ''">#{videoResolution},</if>
