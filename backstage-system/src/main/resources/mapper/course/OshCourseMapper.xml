    <sql id="selectCourseVo">
        select id,
               title,
               cover,
               intro,
               service_content,
               price,
               t_price,
               type,
               sub_count,
               create_by,
               create_time,
               update_by,
               update_time,
               remark,
               total_duration,
               video_count,
               sales_count,
               view_count,
               like_count,
               comment_count,
               rating_score,
               free_type,
               after_service_days,
               status,
               exam_id
        from osh_course
    </sql>

    <!-- 查询课程详情 -->
    <select id="selectCourseById" parameterType="Long" resultMap="OshCouresResult">
        <include refid="selectCourseVo"/>
        where id = #{id}
    </select>

    <!-- 根据条件查询课程列表 -->
    <select id="selectCourseList" resultMap="OshCouresResult">
        <include refid="selectCourseVo"/>
        order by create_time
    </select>

    <select id="pageQuerySearchCourse" parameterType="com.backstage.system.request.CourseSearchRequest" resultMap="OshCouresResult">
        select distinct
        <include refid="searchCourseColumns"/>
        from osh_course c
        left join osh_course_tag_rel ctr on ctr.course_id = c.id
            and ctr.delete_flag = 0
        left join osh_course_tag ct on ct.id = ctr.tag_id
            and ct.delete_flag = 0
            and ct.status = 1
        <where>
            c.delete_flag = 0
            and c.status = 2
            <if test="keyword != null and keyword != ''">
                and c.title like concat('%', #{keyword}, '%')
            </if>
            <if test="tags != null and tags.size() > 0">
                and ct.name in
                <foreach collection="tags" item="tag" open="(" separator="," close=")">
                    #{tag}
                </foreach>
            </if>
        </where>
        order by c.create_time desc, c.id desc
    </select>

    <select id="getCourseDetail" resultMap="OshCourseDetailResult">
        select
        <include refid="courseDetailColumns"/>,
        ct.id as tag_id,
        ct.name as tag_name,
        ct.sort as tag_sort,

        IFNULL(
        CASE WHEN ocb.pay_status = 'paid' THEN 1 ELSE 0 END,
        0
        ) AS buy_flag
        from osh_course c
        left join osh_course_tag_rel ctr on ctr.course_id = c.id
            and ctr.delete_flag = 0
        left join osh_course_tag ct on ct.id = ctr.tag_id
            and ct.delete_flag = 0
            and ct.status = 1
        left join osh_course_buy ocb
            on c.id = ocb.course_id
            and ocb.pay_status= 'paid'
            and ocb.user_id = #{userId}
        where c.id = #{id}
        and c.delete_flag = 0
        and c.status = 2
    </select>

    <select id="selectCourseSectionList" parameterType="Long" resultMap="OshCourseSectionResult">
        select id,
               course_id,
               parent_id,
               title,
               sort,
               free_flag,
               duration,
               media_url,
               text_content,
               cover,
               video_codec,
               video_bitrate,
               video_resolution,
               file_size,
               subtitle_url,
               type,
               status,
               exam_id,
               delete_flag,
               create_by,
               create_time,
               update_by,
               update_time
        from osh_course_section
        where course_id = #{courseId}
          and delete_flag = 0
          and status = 1
        order by sort asc, id asc
    </select>

    <select id="countCourseSectionInCourse" resultType="java.lang.Integer">
        select count(1)
        from osh_course_section
        where course_id = #{courseId}
          and id = #{sectionId}
          and delete_flag = 0
    </select>

    <select id="selectTextCourseSectionContent" parameterType="Long" resultType="java.lang.String">
        select text_content
        from osh_course_section
        where id = #{sectionId}
          and type = 'text'
          and status = 1
          and delete_flag = 0
    </select>

    <select id="getCourseSectionContent" resultType="java.lang.String">
        select case
                   when type = 'text' then text_content
                   when type = 'video' then media_url
                   else ''
                   end as content
        from osh_course_section
        where 0 = 0
          and id = #{sectionId}
          and status = 0
          and delete_flag = 0
    </select>

    <select id="isUserBuyCourseOrFreeCourse" resultType="java.lang.Integer">
        select COUNT(1) as num
        from osh_course_buy ocb
            left join osh_course oc on oc.id = ocb.course_id
        where course_id = #{courseId}
          and user_id = #{userId}
          and pay_status = 'paid'
          and status = 1

        union

        select count(1) as num
        from osh_course
        where 0=0
        and id = #{courseId}
        and ( free_type = 0 or free_type = 2 )
        and delete_flag = 0

        union

        select count(1) as num
        from osh_course_section
        where id = #{courseId}
        and status = 0
        and delete_flag = 0
        and free_flag = 1
    </select>

    <select id="countUserBoughtCourse" resultType="java.lang.Integer">
        select count(1)
        from osh_course_buy
        where course_id = #{courseId}
          and user_id = #{userId}
          and pay_status = 'paid'
          and delete_flag = 0
    </select>

    <select id="countFreeCourse" resultType="java.lang.Integer">
        select count(1)
        from osh_course
        where id = #{courseId}
          and delete_flag = 0
          and status = 2
          and free_type in (0, 2)
    </select>

    <select id="countFreeSectionInCourse" resultType="java.lang.Integer">
        select count(1)
        from osh_course_section
        where course_id = #{courseId}
          and id = #{sectionId}
          and delete_flag = 0
          and status = 1
          and free_flag = 1
    </select>

