<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backstage.system.mapper.course.OshCourseMapper">
    
    <resultMap type="OshCourse" id="OshCouresResult">
        <result property="id"   column="id"    />
        <result property="title"   column="title"    />
        <result property="cover"   column="cover"    />
        <result property="tryContent"   column="try"    />
        <result property="price"   column="price"    />
        <result property="tPrice"   column="t_price"    />
        <result property="type"   column="type"    />
        <result property="goodCount"   column="good_count"    />
        <result property="midCount"   column="mid_count"    />
        <result property="badCount"   column="bad_count"    />
        <result property="favaCount"   column="fava_count"    />
        <result property="buyCount"   column="buy_count"    />
        <result property="subCount"   column="sub_count"    />
        <result property="freeLessonCount"   column="free_lesson_count"    />
        <result property="status"   column="status"    />
        <result property="isfava"   column="isfava"    />
        <result property="isbuy"   column="isbuy"    />
        <result property="remark"   column="remark"    />
        <result property="createTime"   column="create_time"    />
        <result property="updateTime"   column="update_time"    />
    </resultMap>

    <sql id="selectCourseVo">
        select id, title, cover, price, t_price, type, status, buy_count, good_count, mid_count, bad_count,
               free_lesson_count, sub_count, isfava, isbuy, remark, create_time, update_time from osh_course
    </sql>

    <!-- 查询课程详情 -->
    <select id="selectCourseById" parameterType="Long" resultMap="OshCouresResult">
        <include refid="selectCourseVo"/>
        where id = #{id} AND delete_flag = 0
    </select>

    <!-- 根据条件查询课程列表 -->
    <select id="selectCourseList" resultMap="OshCouresResult">
        <include refid="selectCourseVo"/>
        <where>
            AND delete_flag = 0
            <if test="columnId != null">
                and column_id = #{columnId}
            </if>
        </where>
    </select>

    <!-- 多标签 + 关键字 + 动态排序查询课程列表 -->
    <select id="selectCourseListByCondition" parameterType="java.util.Map" resultMap="OshCouresResult">
        SELECT DISTINCT c.id, c.title, c.cover, c.price, c.t_price, c.type, c.status,
                        c.buy_count, c.good_count, c.mid_count, c.bad_count, c.fava_count,
                        c.free_lesson_count, c.sub_count, c.isfava,c.isbuy,c.remark, c.create_time, c.update_time
        FROM osh_course c
        <if test="tagIds != null and tagIds.size() > 0">
            INNER JOIN osh_course_tag_rel tr ON c.id = tr.course_id AND tr.delete_flag = 0
        </if>
        <where>
            c.delete_flag = 0
            AND c.status = 1
            <if test="tagIds != null and tagIds.size() > 0">
                AND tr.tag_id IN
                <foreach collection="tagIds" item="tagId" open="(" separator="," close=")">
                    #{tagId}
                </foreach>
            </if>
            <if test="keyword != null and keyword != ''">
                AND c.title LIKE #{keyword}
            </if>
        </where>
        <choose>
            <when test="sortBy == 'price'">
                ORDER BY c.price ${sortOrder}
            </when>
            <when test="sortBy == 'buy_count'">
                ORDER BY c.buy_count ${sortOrder}
            </when>
            <when test="sortBy == 'good_count'">
                ORDER BY c.good_count ${sortOrder}
            </when>
            <when test="sortBy == 'fava_count'">
                ORDER BY c.fava_count ${sortOrder}
            </when>
            <otherwise>
                ORDER BY c.create_time ${sortOrder}
            </otherwise>
        </choose>
    </select>

    <!-- 新增课程 -->
    <insert id="insertCourse" parameterType="OshCourse" useGeneratedKeys="true" keyProperty="id">
        insert into osh_course
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="cover != null and cover != ''">cover,</if>
            <if test="tryContent != null">try,</if>
            <if test="price != null">price,</if>
            <if test="tPrice != null">t_price,</if>
            <if test="type != null and type != ''">type,</if>
<!--            <if test="subCount != null">sub_count,</if>-->
<!--            <if test="columnId != null">column_id,</if>-->
<!--            <if test="appid != null and appid != ''">appid,</if>-->
<!--            <if test="isbuy != null">isbuy,</if>-->
<!--            <if test="isfava != null">isfava,</if>-->
<!--            <if test="extField1 != null and extField1 != ''">ext1,</if>-->
<!--            <if test="extField2 != null and extField2 != ''">ext2,</if>-->
<!--            <if test="extField3 != null">ext3,</if>-->
<!--            <if test="extField4 != null">ext4,</if>-->
<!--            <if test="extField5 != null">ext5,</if>-->
<!--            <if test="extField6 != null">ext6,</if>-->
<!--            <if test="extField7 != null">ext7,</if>-->
<!--            <if test="extField8 != null">ext8,</if>-->
            <if test="remark != null and remark != ''">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="cover != null and cover != ''">#{cover},</if>
            <if test="tryContent != null">#{tryContent},</if>
            <if test="price != null">#{price},</if>
            <if test="tPrice != null">#{tPrice},</if>
            <if test="type != null and type != ''">#{type},</if>
<!--            <if test="subCount != null">#{subCount},</if>-->
<!--            <if test="columnId != null">#{columnId},</if>-->
<!--            <if test="appid != null and appid != ''">#{appid},</if>-->
<!--            <if test="isbuy != null">#{isbuy},</if>-->
<!--            <if test="isfava != null">#{isfava},</if>-->
<!--            <if test="extField1 != null and extField1 != ''">#{extField1},</if>-->
<!--            <if test="extField2 != null and extField2 != ''">#{extField2},</if>-->
<!--            <if test="extField3 != null">#{extField3},</if>-->
<!--            <if test="extField4 != null">#{extField4},</if>-->
<!--            <if test="extField5 != null">#{extField5},</if>-->
<!--            <if test="extField6 != null">#{extField6},</if>-->
<!--            <if test="extField7 != null">#{extField7},</if>-->
<!--            <if test="extField8 != null">#{extField8},</if>-->
            <if test="remark != null and remark != ''">#{remark},</if>
         </trim>
    </insert>

    <!-- 修改课程 -->
    <update id="updateCourse" parameterType="OshCourse">
        update osh_course
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="cover != null and cover != ''">cover = #{cover},</if>
            <if test="tryContent != null">try = #{tryContent},</if>
            <if test="price != null">price = #{price},</if>
            <if test="tPrice != null">t_price = #{tPrice},</if>
            <if test="type != null and type != ''">type = #{type},</if>
<!--            <if test="subCount != null">sub_count = #{subCount},</if>-->
<!--            <if test="columnId != null">column_id = #{columnId},</if>-->
<!--            <if test="appid != null and appid != ''">appid = #{appid},</if>-->
<!--            <if test="isbuy != null">isbuy = #{isbuy},</if>-->
<!--            <if test="isfava != null">isfava = #{isfava},</if>-->
<!--            <if test="extField1 != null and extField1 != ''">ext1 = #{extField1},</if>-->
<!--            <if test="extField2 != null and extField2 != ''">ext2 = #{extField2},</if>-->
<!--            <if test="extField3 != null">ext3 = #{extField3},</if>-->
<!--            <if test="extField4 != null">ext4 = #{extField4},</if>-->
<!--            <if test="extField5 != null">ext5 = #{extField5},</if>-->
<!--            <if test="extField6 != null">ext6 = #{extField6},</if>-->
<!--            <if test="extField7 != null">ext7 = #{extField7},</if>-->
<!--            <if test="extField8 != null">ext8 = #{extField8},</if>-->
            <if test="remark != null and remark != ''">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <!-- 删除课程 -->
    <delete id="deleteCourseById" parameterType="Long">
        delete from osh_course where id = #{id}
    </delete>

    <!-- 批量删除课程 -->
    <delete id="deleteCourseByIds" parameterType="String">
        delete from osh_course where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <!-- 增加课程收藏计数 -->
    <update id="incrementFavaCount" parameterType="java.util.Map">
        UPDATE osh_course SET fava_count = fava_count + 1 WHERE id = #{courseId}
    </update>
    
    <!-- 减少课程收藏计数 -->
    <update id="decrementFavaCount" parameterType="java.util.Map">
        UPDATE osh_course SET fava_count = GREATEST(fava_count - 1, 0) WHERE id = #{courseId}
    </update>
    
    <!-- 更新课程章节数量 -->
    <update id="updateCourseSubCount" parameterType="java.util.Map">
        UPDATE osh_course SET sub_count = #{subCount} WHERE id = #{id}
    </update>
</mapper>
