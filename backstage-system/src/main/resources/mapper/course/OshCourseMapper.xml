    <select id="pageQuerySearchCourse" parameterType="com.backstage.system.request.CourseSearchRequest" resultMap="CourseSearchLoginResult">
        select distinct
        <include refid="searchCourseColumns"/>,
        0 as collection_flag,
        0 as buy_flag,
        (ifnull(c.sales_count, 0) * 2 + ifnull(c.collection_count, 0)) as sort_score
        from osh_course c
        left join osh_course_tag_rel ctr on ctr.course_id = c.id
            and ctr.delete_flag = 0
        left join osh_course_tag ct on ct.id = ctr.tag_id
            and ct.delete_flag = 0
            and ct.status = 1
        <where>
            c.delete_flag = 0
            and c.status = 2
            <if test="keyword != null and keyword != ''">
                and c.title like concat('%', #{keyword}, '%')
            </if>
            <if test="tags != null and tags.size() > 0">
                and ct.name in
                <foreach collection="tags" item="tag" open="(" separator="," close=")">
                    #{tag}
                </foreach>
            </if>
        </where>
        order by sort_score desc,c.create_time desc
    </select>

    <select id="pageQueryLoginSearchCourse" resultMap="CourseSearchLoginResult">
        select distinct
        <include refid="searchCourseColumns"/>,
        case
            when exists (
                select 1
                from osh_course_collection occ2
                where occ2.course_id = c.id
                  and occ2.user_id = #{userId}
                  and occ2.delete_flag = 0
            ) then 1 else 0
        end as collection_flag,
        case
            when exists (
                select 1
                from osh_course_buy ocb
                where ocb.course_id = c.id
                  and ocb.user_id = #{userId}
                  and ocb.pay_status = 'paid'
            ) then 1 else 0
        end as buy_flag,
        (ifnull(c.sales_count, 0) * 2 + ifnull(c.collection_count, 0)) as sort_score
        from osh_course c
        left join osh_course_tag_rel ctr on ctr.course_id = c.id
            and ctr.delete_flag = 0
        left join osh_course_tag ct on ct.id = ctr.tag_id
            and ct.delete_flag = 0
            and ct.status = 1
        <where>
            c.delete_flag = 0
            and c.status = 2
            <if test="request.keyword != null and request.keyword != ''">
                and c.title like concat('%', #{request.keyword}, '%')
            </if>
            <if test="request.tags != null and request.tags.size() > 0">
                and ct.name in
                <foreach collection="request.tags" item="tag" open="(" separator="," close=")">
                    #{tag}
                </foreach>
            </if>
        </where>
        order by buy_flag desc, sort_score desc, c.create_time desc, c.id desc
    </select>

    <select id="pageQueryUserCollectionCourse" resultMap="OshCouresResult">
        select distinct
        <include refid="searchCourseColumns"/>
        from osh_course c
        inner join osh_course_collection occ on occ.course_id = c.id
            and occ.user_id = #{userId}
            and occ.delete_flag = 0
        left join osh_course_tag_rel ctr on ctr.course_id = c.id
            and ctr.delete_flag = 0
        left join osh_course_tag ct on ct.id = ctr.tag_id
            and ct.delete_flag = 0
            and ct.status = 1
        <where>
            c.delete_flag = 0
            and c.status = 2
            <if test="request.keyword != null and request.keyword != ''">
                and c.title like concat('%', #{request.keyword}, '%')
            </if>
            <if test="request.tags != null and request.tags.size() > 0">
                and ct.name in
                <foreach collection="request.tags" item="tag" open="(" separator="," close=")">
                    #{tag}
                </foreach>
            </if>
        </where>
        order by occ.create_time desc, c.id desc
    </select>

    <select id="getCourseDetail" resultMap="OshCourseDetailResult">
        select
        <include refid="courseDetailColumns"/>,
        ct.id as tag_id,
        ct.name as tag_name,
        ct.sort as tag_sort,

        IFNULL(
        CASE WHEN ocb.pay_status = 'paid' THEN 1 ELSE 0 END,
        0
        ) AS buy_flag
        from osh_course c
        left join osh_course_tag_rel ctr on ctr.course_id = c.id
            and ctr.delete_flag = 0
        left join osh_course_tag ct on ct.id = ctr.tag_id
            and ct.delete_flag = 0
            and ct.status = 1
        left join osh_course_buy ocb
            on c.id = ocb.course_id
            and ocb.pay_status= 'paid'
            and ocb.user_id = #{userId}
        where c.id = #{id}
        and c.delete_flag = 0
        and c.status = 2
    </select>

