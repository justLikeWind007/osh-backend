    <select id="getCourseSectionContent" resultType="java.lang.String">
        select case
                   when type = 'text' then text_content
                   when type = 'video' then media_url
                   else ''
                   end as content
        from osh_course_section
        where 0 = 0
          and id = #{sectionId}
          and status = 0
          and delete_flag = 0
    </select>

    <select id="isUserBuyCourseOrFreeCourse" resultType="java.lang.Integer">
        select COUNT(1) as num
        from osh_course_buy ocb
            left join osh_course oc on oc.id = ocb.course_id
        where course_id = #{courseId}
          and user_id = #{userId}
          and pay_status = 'paid'
          and status = 1

        union

        select count(1) as num
        from osh_course
        where 0=0
        and id = #{courseId}
        and ( free_type = 0 or free_type = 2 )
        and delete_flag = 0

        union

        select count(1) as num
        from osh_course_section
        where id = #{courseId}
        and status = 0
        and delete_flag = 0
        and free_flag = 1
    </select>

    <select id="countUserBoughtCourse" resultType="java.lang.Integer">
        select count(1)
        from osh_course_buy
        where course_id = #{courseId}
          and user_id = #{userId}
          and pay_status = 'paid'
          and delete_flag = 0
    </select>

    <select id="countFreeCourse" resultType="java.lang.Integer">
        select count(1)
        from osh_course
        where id = #{courseId}
          and delete_flag = 0
          and status = 2
          and free_type in (0, 2)
    </select>

    <select id="countFreeSectionInCourse" resultType="java.lang.Integer">
        select count(1)
        from osh_course_section
        where course_id = #{courseId}
          and id = #{sectionId}
          and delete_flag = 0
          and status = 1
          and free_flag = 1
    </select>

    <update id="increaseQuestionCount">
        update osh_course
        set question_count = ifnull(question_count, 0) + 1
        where id = #{courseId}
          and delete_flag = 0
    </update>

    <update id="increaseCollectionCount">
        update osh_course
        set collection_count = ifnull(collection_count, 0) + 1
        where id = #{courseId}
          and delete_flag = 0
    </update>

    <update id="decreaseCollectionCount">
        update osh_course
        set collection_count = if(ifnull(collection_count, 0) > 0, collection_count - 1, 0)
        where id = #{courseId}
          and delete_flag = 0
    </update>

    <!-- 多标签 + 关键字 + 动态排序查询课程列表 -->
    <select id="selectCourseListByCondition" parameterType="java.util.Map" resultMap="OshCouresResult">
        SELECT DISTINCT c.id, c.title, c.cover, c.price, c.t_price, c.type, c.status,
                        c.free_lesson_count, c.sub_count, c.remark, c.create_time, c.update_time
        FROM osh_course c
        <if test="tagIds != null and tagIds.size() > 0">
            INNER JOIN osh_course_tag_rel tr ON c.id = tr.course_id AND tr.delete_flag = 0
        </if>
        <where>
            c.delete_flag = 0
            AND c.status = 1
            <if test="tagIds != null and tagIds.size() > 0">
                AND tr.tag_id IN
                <foreach collection="tagIds" item="tagId" open="(" separator="," close=")">
                    #{tagId}
                </foreach>
            </if>
            <if test="keyword != null and keyword != ''">
                AND c.title LIKE #{keyword}
            </if>
        </where>
        <choose>
            <when test="sortBy == 'price'">
                ORDER BY c.price ${sortOrder}
            </when>
            <when test="sortBy == 'buy_count'">
                ORDER BY c.buy_count ${sortOrder}
            </when>
            <otherwise>
                ORDER BY c.create_time ${sortOrder}
            </otherwise>
        </choose>
    </select>

