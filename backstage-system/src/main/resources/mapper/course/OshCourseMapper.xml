    <!-- 删除课程 -->
    <delete id="deleteCourseById" parameterType="Long">
        delete from osh_course where id = #{id}
    </delete>

    <!-- 批量删除课程 -->
    <delete id="deleteCourseByIds" parameterType="String">
        delete from osh_course where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="getCourseMaterials" resultMap="OshCourseMaterial">
        select id,
               course_id,
               name,
               url,
               file_size,
               file_type,
               download_count,
               is_pay_only as pay_only,
               sort,
               delete_flag,
               create_by,
               create_time,
               update_by,
               update_time
        from osh_course_material
        where course_id = #{courseId}
          and delete_flag = 0
        order by sort asc, id asc
    </select>
