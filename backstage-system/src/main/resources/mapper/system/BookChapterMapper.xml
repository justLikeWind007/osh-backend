<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backstage.system.mapper.book.BookChapterMapper">

    <resultMap type="com.backstage.system.domain.vo.book.BookChapterVO" id="BookChapterVOResult">
        <result property="id" column="id" />
        <result property="title" column="title" />
        <result property="orderby" column="orderby" />
        <result property="isfree" column="isfree" />
    </resultMap>

    <sql id="selectBookChapterVo">
        select id, book_id, title, content, orderby, isfree, del_flag,
               create_by, create_time, update_by, update_time, remark
        from osh_book_chapter
    </sql>

    <select id="selectBookChapterByBookIdAndId" resultType="com.backstage.system.domain.BookChapter">
        <include refid="selectBookChapterVo"/>
        where book_id = #{bookId} and id = #{id} and del_flag = '0'
    </select>

    <select id="selectBookChapterListByBookId" parameterType="Long" resultMap="BookChapterVOResult">
        select id, title, orderby, isfree
        from osh_book_chapter
        where book_id = #{bookId} and del_flag = '0'
        order by orderby asc
    </select>

</mapper>
