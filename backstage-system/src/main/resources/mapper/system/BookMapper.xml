<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backstage.system.mapper.book.BookMapper">

    <resultMap type="com.backstage.system.domain.vo.book.BookListVO" id="BookListResult">
        <result property="id" column="id" />
        <result property="title" column="title" />
        <result property="cover" column="cover" />
        <result property="desc" column="description" />
        <result property="price" column="price" />
        <result property="tPrice" column="original_price" />
        <result property="subCount" column="sub_count" />
    </resultMap>

    <select id="getBookPageList" parameterType="BookDO" resultType="com.backstage.system.domain.vo.book.BookListVO">
        SELECT
            book.id, book.title, book.cover, book.description, book.price, book.original_price, book.sub_count,
            GROUP_CONCAT(DISTINCT tag.tag_name) AS tag_names
        FROM
            osh_book book
            LEFT JOIN osh_book_tag tag ON book.id = tag.book_id AND tag.del_flag = '0'
        <where>
            book.del_flag = '0' and book.status = '0'
            <if test="reqVO.tagNameList != null and reqVO.tagNameList.size() > 0">
                and tag.tag_name in
                <foreach item="tagName" collection="reqVO.tagNameList" separator="," open="(" close=")" index="">
                    #{tagName}
                </foreach>
            </if>
            <if test="reqVO.title != null and reqVO.title != ''">
                and book.title like concat('%', #{reqVO.title}, '%')
            </if>
        </where>
        GROUP BY book.id
        order by book.create_time desc
    </select>

</mapper>
