<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backstage.system.mapper.info_gap.OshInfoGapFollowMapper">

    <resultMap id="FollowResultMap" type="com.backstage.system.domain.info_gap.OshInfoGapFollow">
        <id column="id" property="id" />
        <result column="user_id" property="userId" />
        <result column="target_user_id" property="targetUserId" />
        <result column="create_time" property="createTime" />
    </resultMap>

    <select id="selectFollowRecord" resultMap="FollowResultMap">
        SELECT id, user_id, target_user_id, create_time
        FROM osh_info_gap_follow
        WHERE user_id = #{userId}
        AND target_user_id = #{targetUserId}
        LIMIT 1
    </select>

    <delete id="deleteFollowRecord">
        DELETE FROM osh_info_gap_follow
        WHERE id = #{id}
    </delete>

    <insert id="insertFollowRecord" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO osh_info_gap_follow (
        user_id,
        target_user_id,
        create_time
        ) VALUES (
        #{userId},
        #{targetUserId},
        NOW()
        )
    </insert>

</mapper>