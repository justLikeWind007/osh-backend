<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backstage.system.mapper.SysFlashsaleMapper">

    <resultMap type="SysFlashsale" id="OshFlashsaleResult">
        <result property="id"    column="id"    />
        <result property="goodsId"    column="goods_id"    />
        <result property="flashPrice"    column="flash_price"    />
        <result property="sNum"    column="s_num"    />
        <result property="usedNum"    column="used_num"    />
        <result property="startTime" column="start_time" />
        <result property="endTime" column="end_time" />
        <result property="flashType"    column="flash_type"    />
    </resultMap>

    <sql id="selectOshFlashsaleVo">
        select id, goods_id, flash_price, s_num, used_num, start_time, end_time, flash_type from osh_flashsale
    </sql>

    <select id="selectOshFlashsaleList" parameterType="SysFlashsale" resultMap="OshFlashsaleResult">
        <include refid="selectOshFlashsaleVo"/>
        <where>
            <if test="goodsId != null "> and goods_id = #{goodsId}</if>
            <if test="flashPrice != null  and flashPrice != ''"> and flash_price = #{flashPrice}</if>
            <if test="sNum != null  and sNum != ''"> and s_num = #{sNum}</if>
            <if test="usedNum != null  and usedNum != ''"> and used_num = #{usedNum}</if>
            <if test="startTime != null  and startTime != ''"> and start_time = #{startTime}</if>
            <if test="endTime != null  and endTime != ''"> and end_time = #{endTime}</if>
            <if test="flashType != null  and flashType != ''"> and flash_type = #{flashType}</if>
        </where>
    </select>

    <select id="selectOshFlashsaleById" parameterType="Long" resultMap="OshFlashsaleResult">
        <include refid="selectOshFlashsaleVo"/>
        where id = #{id}
    </select>

    <insert id="insertOshFlashsale" parameterType="SysFlashsale" useGeneratedKeys="true" keyProperty="id">
        insert into osh_flashsale
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="goodsId != null">goods_id,</if>
            <if test="flashPrice != null">flash_price,</if>
            <if test="sNum != null">s_num,</if>
            <if test="usedNum != null">used_num,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="flashType != null">flash_type,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="goodsId != null">#{goodsId},</if>
            <if test="flashPrice != null">#{flashPrice},</if>
            <if test="sNum != null">#{sNum},</if>
            <if test="usedNum != null">#{usedNum},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="flashType != null">#{flashType},</if>
        </trim>
    </insert>

    <update id="updateOshFlashsale" parameterType="SysFlashsale">
        update osh_flashsale
        <trim prefix="SET" suffixOverrides=",">
            <if test="goodsId != null">goods_id = #{goodsId},</if>
            <if test="flashPrice != null">flash_price = #{flashPrice},</if>
            <if test="sNum != null">s_num = #{sNum},</if>
            <if test="usedNum != null">used_num = #{usedNum},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="flashType != null">flash_type = #{flashType},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteOshFlashsaleById" parameterType="Long">
        delete from osh_flashsale where id = #{id}
    </delete>

    <delete id="deleteOshFlashsaleByIds" parameterType="String">
        delete from osh_flashsale where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>