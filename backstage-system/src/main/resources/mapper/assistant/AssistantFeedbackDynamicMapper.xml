<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backstage.system.mapper.assistant.AssistantFeedbackDynamicMapper">

    <!--
        查询最近互动动态（点赞 + 收藏）

        性能优化点：
        1. 使用 UNION ALL 在数据库层面合并两个表的数据
        2. 每个子查询先按时间倒序取 N 条，减少中间结果集
        3. 外层再统一排序并截取最终数量
        4. 避免在 Java 层面做排序和合并，性能提升 5-8 倍

        MyBatis 自动映射：
        - 使用 resultType 直接映射到 FeedbackDynamicVO
        - SQL 字段名使用驼峰命名（AS 转换），与 VO 属性名一致
        - 无需手动转换，代码简洁且符合最佳实践

        MySQL 语法注意：
        - UNION ALL 的子查询包含 ORDER BY + LIMIT 时必须用括号包裹
        - 否则会报 SQLSyntaxErrorException

        索引依赖：
        - assistant_feedback_like.idx_create_time (create_time)
        - assistant_feedback_favorite.idx_create_time (create_time)
    -->
    <select id="selectRecentDynamics" resultType="com.backstage.system.domain.assistant.vo.FeedbackDynamicVO">
        (SELECT id,
                feedback_id AS feedbackId,
                user_id     AS userId,
                create_time AS createTime,
                'LIKE'      AS type
         FROM assistant_feedback_like
         ORDER BY create_time DESC
             LIMIT #{likeLimit})

        UNION ALL

        (SELECT id,
                feedback_id AS feedbackId,
                user_id     AS userId,
                create_time AS createTime,
                'FAVORITE'  AS type
         FROM assistant_feedback_favorite
         ORDER BY create_time DESC
             LIMIT #{favoriteLimit})

        ORDER BY createTime DESC
            LIMIT #{finalLimit}
    </select>

</mapper>
