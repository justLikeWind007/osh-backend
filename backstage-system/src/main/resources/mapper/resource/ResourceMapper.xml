<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backstage.system.mapper.resource.ResourceMapper">

    <resultMap type="com.backstage.system.domain.vo.resource.ResourceVO" id="ResourceVOResult">
        <result property="id" column="id" />
        <result property="name" column="name" />
        <result property="type" column="type" />
        <result property="remark" column="remark" />
        <result property="filePath" column="file_path" />
    </resultMap>

    <select id="selectVOByIds" resultMap="ResourceVOResult">
        SELECT id, name, type, remark, file_path
        FROM osh_resource
        WHERE delete_flag = 0
        <if test="ids != null and ids.size() > 0">
            AND id IN
            <foreach collection="ids" item="rid" open="(" separator="," close=")">
                #{rid}
            </foreach>
        </if>
        ORDER BY id DESC
    </select>

    <select id="selectVOByGroupId" resultMap="ResourceVOResult">
        SELECT 
            r.id,
            r.name,
            r.type,
            r.remark,
            r.file_path
        FROM osh_resource_group_resource rel
        INNER JOIN osh_resource r ON rel.resource_id = r.id
        WHERE rel.group_id = #{groupId}
          AND rel.delete_flag = 0
          AND r.delete_flag = 0
        ORDER BY rel.sort_no ASC, r.id DESC
    </select>

</mapper>
