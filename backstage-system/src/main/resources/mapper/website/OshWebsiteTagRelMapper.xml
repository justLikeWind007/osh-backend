<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backstage.system.mapper.website.OshWebsiteTagRelMapper">

    <resultMap id="BaseResultMap" type="com.backstage.system.domain.website.OshWebsiteTagRel">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="websiteId" column="website_id" jdbcType="BIGINT"/>
        <result property="tagId" column="tag_id" jdbcType="BIGINT"/>
        <result property="createBy" column="create_by" jdbcType="VARCHAR"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateBy" column="update_by" jdbcType="VARCHAR"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
        <result property="deleteFlag" column="delete_flag" jdbcType="TINYINT"/>
    </resultMap>

    <!-- 批量插入网站标签关联关系 -->
    <insert id="batchInsertRel">
        INSERT INTO osh_website_tag_rel (website_id, tag_id, delete_flag)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.websiteId}, #{item.tagId}, 0)
        </foreach>
    </insert>

    <!-- 根据单个网站ID软删除关联关系 -->
    <update id="deleteByWebsiteId">
        UPDATE osh_website_tag_rel
        SET delete_flag = 1
        WHERE website_id = #{websiteId}
          AND delete_flag = 0
    </update>

    <!-- 根据网站ID批量软删除关联关系 -->
    <update id="deleteByWebsiteIds">
        UPDATE osh_website_tag_rel
        SET delete_flag = 1
        WHERE website_id IN
        <foreach collection="websiteIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

</mapper>
