{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0
  },
  "mappings": {
    "dynamic": false,
    "properties": {
      "id": {
        "type": "long"
      },
      "name": {
        "type": "text",
        "analyzer": "ik_max_word",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 256
          }
        }
      },
      "url": {
        "type": "keyword",
        "ignore_above": 512
      },
      "description": {
        "type": "text",
        "analyzer": "ik_max_word"
      },
      "logoUrl": {
        "type": "keyword",
        "ignore_above": 512
      },
      "tags": {
        "type": "keyword",
        "ignore_above": 128
      },
      "clickCount": {
        "type": "integer"
      },
      "goodCount": {
        "type": "integer"
      },
      "midCount": {
        "type": "integer"
      },
      "badCount": {
        "type": "integer"
      },
      "collectionCount": {
        "type": "integer"
      },
      "ratingScore": {
        "type": "scaled_float",
        "scaling_factor": 100
      },
      "auditTime": {
        "type": "date",
        "format": "strict_date_optional_time||epoch_millis"
      }
    }
  }
}
